---
import "@fontsource-variable/dm-sans/opsz.css";
import { GLAZE_GALLERY_URL, GLAZE_GALLERY_STUDIO } from "astro:env/server";
import "@/styles/global.css";
import { siteName } from "@/constants";
import { studio } from "@/utils/studio";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

type Props = {
  /**
   * Optional page title.
   *
   * If included, the page title will be set to `{title} | {siteName}`; otherwise, the
   * title will just be `{siteName}`.
   */
  title?: string;
};

const { title } = Astro.props;
const titlePrefix = title ? `${title} - ` : "";

// Paint the repeating kraft-paper texture over the studio's background color.
// The asset is referenced directly (not via getImage) because the site renders
// on-demand on Cloudflare, which can't run sharp for runtime image optimization;
// Astro emits the imported tile as a static asset, and a noisy paper texture
// tiled at 600px doesn't need per-density variants to look crisp.
const backgroundImageCss = {
  backgroundImage: `url("${studio.backgroundTile.src}")`,
  backgroundSize: "600px auto",
};
---

<!doctype html>
<html lang="en" data-studio={studio.key} style={{ backgroundColor: studio.backgroundColor }}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={`${GLAZE_GALLERY_STUDIO} glaze gallery.`} />
    <meta name="theme-color" content={studio.backgroundColor} />
    <title>{titlePrefix}{siteName}</title>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: `${GLAZE_GALLERY_STUDIO} Glaze Gallery`,
        url: `${GLAZE_GALLERY_URL}/`,
      })}
    />
    {
      studio.favicons.map((favicon) => (
        <link rel="icon" href={favicon.href} type={favicon.type} sizes={favicon.sizes} />
      ))
    }
  </head>
  <body class="text-clay" style={backgroundImageCss}>
    <Header />
    <main class="flex flex-col gap-5 p-5 text-lg">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html {
    font-family: "DM Sans Variable", sans-serif;
  }

  a {
    color: var(--color-clay-link);
    text-decoration-thickness: 1.5px;
    text-underline-offset: 2px;
  }

  p > a,
  p > obfuscated-email > a {
    text-decoration-line: underline;
  }
</style>
