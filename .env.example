# Published data read by download_data
GLAZE_GALLERY_GLAZE_NAMES=path/to/glaze-names.json
GLAZE_GALLERY_GLAZE_COMBO_INFO=path/to/glaze-combo-info.json
GLAZE_GALLERY_IMAGES_HIGH=path/to/images-high.json
GLAZE_GALLERY_IMAGES_LOW=path/to/images-low.json

# Google source data used by download_images
GLAZE_GALLERY_SPREADSHEET_ID=your-google-spreadsheet-id
GLAZE_GALLERY_DATA_RANGE=Sheet1!A:Z
GLAZE_GALLERY_LAST_SYNCED_CELL=Sheet1!A1

# Astro site configuration; keep this value in sync with .dev.vars
GLAZE_GALLERY_STUDIO=lamanopottery

# Astro authentication secrets; keep these values in sync with .dev.vars
GLAZE_GALLERY_PASSWORD=change-me
GLAZE_GALLERY_JWT_SECRET=replace-with-a-long-random-string
